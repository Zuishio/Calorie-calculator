  <property name="styleSheet">
   <string notr="true">/* Основной фон приложения - глубокий сине-черный */
QMainWindow, QWidget {
    background-color: #0d121c;
    color: #ffffff;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* Карточки (Сводка, приемы пищи) */
QFrame {
    background-color: #1a2230;
    border-radius: 20px;
    border: none;
}

/* Элементы списка питания */
QPushButton#btn_add {
    background-color: #2a3346;
    border-radius: 15px;
    color: white;
}

/* Акцентная кнопка &quot;плюс&quot; с градиентом */
QPushButton#btn_plus {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, 
                                stop:0 #6c63ff, stop:1 #8e88ff);
    border-radius: 30px;
    font-size: 24px;
    font-weight: bold;
    color: white;
}

/* Таблица и списки */
QTableWidget, QListWidget {
    background-color: #1a2230;
    border: none;
    outline: none;
    color: #b0b8c6;
}

QTableWidget::item {
    padding: 15px;
    border-bottom: 1px solid #2a3346;
}

/* Тексты заголовков */
QLabel {
    color: #ffffff;
}

/* Дополнительные подписи (серый цвет) */
QLabel#label_secondary {
    color: #7b8596;
}

QTableWidget {
    background-color: #1a2230; /* Цвет фона таблицы */
    color: #ffffff;           /* БЕЛЫЙ ЦВЕТ ТЕКСТА */
    gridline-color: #2a3346;  /* Цвет сетки */
    border: none;
}

QTableWidget::item {
    color: #ffffff;           /* Гарантированный белый цвет для ячеек */
    padding: 5px;
}

/* Настройка заголовков таблицы (чтобы текст в них тоже был виден) */
QHeaderView::section {
    background-color: #2a3346;
    color: #ffffff;           /* Белый текст заголовков */
    font-weight: bold;
    border: none;
}

QPushButton {
    border-radius: 8px;
    background-color: #2a3346;
    color: white;
    padding: 5px;
}

QComboBox {
    border: 2px solid #7aa2f7; /* Красивая, заметная серо-голубая рамка */
    border-radius: 6px;       /* Мягкое скругление углов */
    padding: 3px 10px;        /* Отступы, чтобы текст не прижимался к краям */
    background-color: #24283b; /* Фон чуть светлее или темнее основного, чтобы выделялся */
    color: #c0caf5;           /* Цвет текста */
}

/* Стиль стрелочки справа */
QComboBox::drop-down {
    border: none;
    background: transparent;
    padding-right: 10px;
}</string>
  </property>
